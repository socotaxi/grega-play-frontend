#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/proc/cygdrive/c/Users/hp/Desktop/APPLI/GREGAPLAY/grega-play-frontend/node_modules/browserslist/node_modules:/proc/cygdrive/c/Users/hp/Desktop/APPLI/GREGAPLAY/grega-play-frontend/node_modules:/proc/cygdrive/c/Users/hp/Desktop/APPLI/GREGAPLAY/node_modules:/proc/cygdrive/c/Users/hp/Desktop/APPLI/node_modules:/proc/cygdrive/c/Users/hp/Desktop/node_modules:/proc/cygdrive/c/Users/hp/node_modules:/proc/cygdrive/c/Users/node_modules:/proc/cygdrive/c/node_modules:/proc/cygdrive/c/Users/hp/Desktop/APPLI/GREGAPLAY/grega-play-frontend/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/proc/cygdrive/c/Users/hp/Desktop/APPLI/GREGAPLAY/grega-play-frontend/node_modules/browserslist/node_modules:/proc/cygdrive/c/Users/hp/Desktop/APPLI/GREGAPLAY/grega-play-frontend/node_modules:/proc/cygdrive/c/Users/hp/Desktop/APPLI/GREGAPLAY/node_modules:/proc/cygdrive/c/Users/hp/Desktop/APPLI/node_modules:/proc/cygdrive/c/Users/hp/Desktop/node_modules:/proc/cygdrive/c/Users/hp/node_modules:/proc/cygdrive/c/Users/node_modules:/proc/cygdrive/c/node_modules:/proc/cygdrive/c/Users/hp/Desktop/APPLI/GREGAPLAY/grega-play-frontend/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../browserslist/cli.js" "$@"
else
  exec node  "$basedir/../browserslist/cli.js" "$@"
fi
