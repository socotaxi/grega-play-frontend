# ==== SUPABASE (PUBLIC) ====
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ==== BACKEND API ====
VITE_BACKEND_URL=http://localhost:3001
# En prod sur Vercel : https://grega-play-backend-production.up.railway.app

# Clé secrète partagée avec le backend (doit correspondre à INTERNAL_API_KEY côté backend)
VITE_BACKEND_API_KEY=change-me-in-production
# Alias utilisé par billingService — même valeur que VITE_BACKEND_API_KEY
VITE_API_SECRET=change-me-in-production

# ==== ADMIN ====
VITE_ADMIN_EMAIL=your-admin-email@example.com

# ==== PUSH (PUBLIC) ====
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
